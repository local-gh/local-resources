PROJECT_NAME=""
NODE_ENV="production"
VERSION="0.1.0"
APP_VERSION="1.0.0"
MANAGER_IP=<manager-ip>
MANAGER_TOKEN=<manager-token>
WORKER_NODES="worker1-ip worker2-ip worker3-ip"
STACKS="ai blog development ecommerce mail s3 core visualizer"
NODE_LABELS="root@localhost:core=manager,ai=manager,blog=manager,ecommerce=manager,s3=manager,visualizer=manager"
AI_ETCD_REPLICAS=1
AI_OLLAMA_REPLICAS=1
AI_OPEN_WEBUI_REPLICAS=1
AI_OPENEDAI_SPEECH_SERVER_REPLICAS=1
AI_STANDALONE_REPLICAS=1
BLOG_GHOST_REPLICAS=1
BLOG_DB_REPLICAS=1
ECOMMERCE_MEDUSA_SERVER_REPLICAS=1
ECOMMERCE_REDIS_REPLICAS=1
# Kubernetes only (docker compose ignores this). Set to 1 to enable Logflare + Studio logs.
# At 0: deployment/service are not applied and any existing resources are removed on deploy.
CORE_ANALYTICS_REPLICAS=0
# Steady-state Logflare use is ~2.5Gi; request below that triggers eviction under node memory pressure.
CORE_ANALYTICS_MEMORY_REQUEST=3Gi
CORE_ANALYTICS_MEMORY_LIMIT=4Gi
CORE_ANALYTICS_ERL_AFLAGS="+MMsco true +S 1:1 +MBas aoffcbf +MBlmbcs 512 +MEas aoffcbf +MElmbcs 512"
CORE_KONG_REPLICAS=1
CORE_AUTH_REPLICAS=1
CORE_REST_REPLICAS=1
CORE_REALTIME_REPLICAS=1
CORE_META_REPLICAS=1
CORE_IMGPROXY_REPLICAS=1
CORE_DB_REPLICAS=1
CORE_REALTIME_REPLICAS=1
CORE_STORAGE_REPLICAS=1
CORE_STUDIO_REPLICAS=1
CORE_SUPAVISOR_REPLICAS=1
# Requires analytics when enabled. Disable on Kubernetes when analytics replicas is 0.
CORE_VECTOR_REPLICAS=0
CORE_VECTOR_MEMORY_REQUEST=256Mi
CORE_VECTOR_MEMORY_LIMIT=512Mi
DEVELOPMENT_PGADMIN_REPLICAS=1
NGINX_REPLICAS=1
S3_MINIO_REPLICAS=1
AI_OLLAMA_STORAGE="100Mi"
AI_OPEN_WEBUI_STORAGE="100Mi"
AI_OPENEDAI_SPEECH_SERVER_CONFIG_STORAGE="100Mi"
AI_OPENEDAI_SPEECH_SERVER_VOICES_STORAGE="5Gi"
AI_STANDALONE_STORAGE="100Mi"
BLOG_GHOST_STORAGE="100Mi"
BLOG_DB_STORAGE="10Gi"
CORE_ANALYTICS_STORAGE="100Mi"
CORE_DB_CONFIG_STORAGE="100Mi"
CORE_DB_DATA_STORAGE="10Gi"
CORE_DB_INIT_SCRIPTS_STORAGE="100Mi"
CORE_DB_MIGRATIONS_STORAGE="100Mi"
CORE_DB_SSL_STORAGE="100Mi"
CORE_DB_STORAGE="100Mi"
CORE_KONG_STORAGE="100Mi"
CORE_IMGPROXY_STORAGE="100Mi"
CORE_STORAGE_STORAGE="100Mi"
CORE_SUPAVISOR_STORAGE="100Mi"
CORE_VECTOR_STORAGE="100Mi"
ECOMMERCE_MEDUSA_SERVER_STORAGE="100Mi"
ECOMMERCE_MEILISEARCH_DATA_STORAGE="100Mi"
NGINX_CONFIG_STORAGE="100Mi"
NGINX_SSL_STORAGE="100Mi"
S3_MINIO_DATA_STORAGE="10Gi"
############
# Nginx
# YOU MUST CHANGE THESE BEFORE GOING INTO PRODUCTION
############

NGINX_SUPABASE_HOST_URL=supabase.localhost
NGINX_DB_HOST_URL=postgres.localhost
NGINX_KONG_HOST_URL=kong.localhost
NGINX_LOGFLARE_HOST_URL=log.localhost
# Nginx server blocks are omitted when the matching *_REPLICAS value is 0 (see setup_nginx.sh).
# Kong declarative config is generated from volumes/api/kong.yml.template (see setup_kong.sh).
NGINX_MEDUSA_HOST_URL=medusa.localhost
NGINX_OPEN_WEBUI_HOST_URL=open-webui.localhost
NGINX_OPENEDAI_SPEECH_SERVER_HOST_URL=openedai-speech.localhost
NGINX_GHOST_ADMIN_HOST_URL=ghost-admin.localhost
NGINX_GHOST_HOST_URL=blog.localhost

NGINX_DIGITALOCEAN_CERTIFICATE_ID=""


